SHELL=/bin/sh
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
CRON_TZ=Asia/Shanghai

*/5 * * * * cd /app && python scripts/refresh_owner_announcement.py
0 4 * * * cd /app && if [ "${SITE_DATA_SOURCE:-json}" = "postgres" ]; then python scripts/run_server_refresh.py; else echo "skip server refresh because SITE_DATA_SOURCE=${SITE_DATA_SOURCE:-json}"; fi
