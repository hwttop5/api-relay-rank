{
  "name": "api-relay-rank",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "python scripts/build_site_data.py && next build",
    "build:analyze": "ANALYZE=true npm run build",
    "start": "next start",
    "prepare": "node .husky/install.mjs",
    "commitlint": "commitlint --edit",
    "site:data": "python scripts/build_site_data.py",
    "site:announcements": "python scripts/fetch_public_content.py --announcements",
    "site:tiers": "python scripts/fetch_public_content.py --multiplier-snapshots",
    "site:invite-links": "python scripts/refresh_invite_links.py --write",
    "site:audit": "python scripts/run_station_audit.py",
    "site:refresh-manual": "python scripts/refresh_quality_rankings.py",
    "site:jobs": "python scripts/run_tasks.py"
  },
  "dependencies": {
    "lucide-react": "^0.554.0",
    "next": "^15.5.4",
    "next-auth": "^4.24.14",
    "pg": "^8.21.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@next/bundle-analyzer": "^16.2.9",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "cssnano": "^8.0.2",
    "husky": "^9.1.7",
    "playwright": "^1.60.0",
    "postcss-import": "^16.1.1",
    "postcss-preset-env": "^11.3.0",
    "typescript": "^5.9.2"
  }
}
